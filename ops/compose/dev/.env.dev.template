#------------------------------------------------------
# Environment template for Development Environment
# Copy to: .env.dev
#------------------------------------------------------

SPRING_PROFILES_ACTIVE=dev

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_AUTH_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App
APP_URL=https://dev.app.time2log.app

# Frontend build
API_BASE_URL=https://dev.admin.aeristo.cc/api

# CORS
CORS_ALLOWED_ORIGINS=https://dev.admin.time2log.app

# Mail provider: "smtp" or "resend"
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@time2log.app

# Resend (when MAIL_PROVIDER=resend)
RESEND_API_KEY=

# SMTP (when MAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_TLS=true
